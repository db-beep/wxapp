.file-uploader {
    width: 80%;
    padding: 15px;
    border: 1px solid #eee;
    border-radius: 8px;
    background-color: #fff;
}

.preview-area {
    width: 100%;
    min-width: 200rpx;
    height: auto;
    margin-bottom: 15px;
    display: flex;
    justify-content: center;
}

.progress-bar {
    margin: 10px 0;
}

.progress-bar text {
    font-size: 12px;
    color: #666;
    margin-left: 10px;
}

.action-buttons {
    display: flex;
    justify-content: center;
    gap: 10px;
}

.action-buttons button {
    margin: 0;
}