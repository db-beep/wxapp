.media-display {
    margin: 15px 0;
    padding: 12px;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
}

.media-container {
    width: 100%;
    border-radius: 6px;
    overflow: hidden;
}

.media-image {
    display: block;
    border-radius: 6px;
}

.media-video {
    width: 100%;
    min-width: 300rpx;
    height: 200px;
    border-radius: 6px;
}

.media-audio {
    width: 100%;
    height: 30px;
}

.download-container {
    display: flex;
    align-items: center;
    padding: 10px;
    background-color: #f8f9fa;
    border-radius: 6px;
}

.file-name {
    flex: 1;
    font-size: 14px;
    color: #333;
    margin: 0 10px;
    word-break: break-all;
}

.download-btn {
    margin-left: 10px;
    font-size: 14px;
    background-color: #4A90E2;
    color: white;
    border-radius: 4px;
    padding: 6px 12px;
    line-height: 1.2;
}

.download-btn::after {
    border: none;
}
