/* 登录容器 */
.login-container {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40rpx;
    box-sizing: border-box;
    overflow: hidden;
  }
  
  /* 背景渐变 */
  .bg-gradient {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
    z-index: -1;
  }
  
  /* 登录卡片 */
  .login-card {
    width: 90%;
    max-width: 600rpx;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 24rpx;
    padding: 60rpx 40rpx;
    box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
    z-index: 1;
  }
  
  /* 标题 */
  .login-title {
    text-align: center;
    margin-bottom: 60rpx;
  }
  
  .login-title text {
    font-size: 48rpx;
    font-weight: bold;
    background: linear-gradient(90deg, #6a11cb, #2575fc);
    -webkit-background-clip: text;
    color: transparent;
  }
  
  /* 表单 */
  .login-form {
    margin-bottom: 40rpx;
  }
  
  /* 自定义输入框样式 */
  .custom-field {
    margin-bottom: 30rpx;
    border-radius: 16rpx;
    overflow: hidden;
    background-color: #f8f8f8;
  }
  
  .custom-field .van-field__label {
    width: 140rpx !important;
    color: #666;
  }
  
  /* 验证码行 */
  .captcha-row {
    display: flex;
    margin-bottom: 30rpx;
  }
  
  .captcha-field {
    flex: 1;
    margin-right: 20rpx;
  }
  
  .captcha-img {
    width: 160rpx;
    height: 80rpx;
    border-radius: 12rpx;
    background-color: #f0f0f0;
    margin: 0
  }
  
  /* 登录按钮 */
  .login-btn {
    margin-top: 40rpx;
    background: linear-gradient(90deg, #6a11cb, #2575fc);
    border: none;
    font-weight: bold;
    letter-spacing: 4rpx;
  }
  
  /* 注册链接 */
  .register-link {
    text-align: center;
    margin-top: 30rpx;
    color: #2575fc;
    font-size: 28rpx;
  }
  
  /* 页脚 */
  .login-footer {
    position: absolute;
    bottom: 40rpx;
    width: 100%;
    text-align: center;
    color: rgba(255, 255, 255, 0.8);
    font-size: 24rpx;
  }
  
  /* 注册弹窗 */
  .register-popup {
    width: 85%;
    max-width: 600rpx;
    padding: 40rpx;
  }
  
  .register-title {
    text-align: center;
    font-size: 36rpx;
    font-weight: bold;
    margin-bottom: 40rpx;
    color: #333;
  }
  
  .register-form {
    margin-bottom: 40rpx;
  }
  
  .register-btns {
    display: flex;
    justify-content: space-between;
    margin-top: 40rpx;
  }
  
  