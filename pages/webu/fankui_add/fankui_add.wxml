<!--components/add-item/add-item.wxml-->
<view class="modal" wx:if="{{show}}">
  <view class="mask" bindtap="onCancel"></view>
  <view class="container">
    <view class="header">我要反馈</view>
    
    <!-- 可滚动的内容区域 -->
    <scroll-view class="content" scroll-y>
      
      <view class="form-item">
        <text class="label">反馈人</text>
        <x-select disabled="{{userInfo.role=='user'}}" value="{{form.userid}}" url="/webu/user/list/select" data-key="form.userid" bind:change="valueChange" labelField="name"/>
      </view>
      <view class="form-item">
        <text class="label require">机构</text>
        <x-select disabled="{{userInfo.role=='institution'}}" value="{{form.inid}}" url="/webu/institution/list/select" data-key="form.inid" bind:change="valueChange" labelField="name"/>
      </view>
      <view class="form-item">
        <text class="label require">反馈内容</text>
        <input maxlength="255" placeholder="请输入反馈内容" value="{{form.title}}" bind:change="valueChange" data-key="form.title" />
      </view>
    </scroll-view>
    
    <!-- 按钮区域 -->
    <view class="footer">
      <view class="btn btn-cancel" bindtap="onCancel">取消</view>
      <view class="btn btn-confirm" bindtap="onConfirm">确认</view>
    </view>
  </view>
</view>

