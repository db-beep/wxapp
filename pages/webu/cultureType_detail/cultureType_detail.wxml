<view class="modal" wx:if="{{show}}">
  <view class="mask" bindtap="onCancel"></view>
  <view class="container">
    <view class="header">非遗文化类型详情</view>
    <scroll-view class="content" scroll-y>
      <view class="form-item">
        <text class="label">非遗类型名</text>
        <input disabled="true" value="{{form.name}}" />
      </view>
      <view class="form-item">
        <text class="label">类型简介</text>
        <input disabled="true" value="{{form.description}}" />
      </view>
      
    </scroll-view>
    
    <view class="footer">
      <view class="btn btn-confirm" bindtap="onCancel">关闭</view>
    </view>
  </view>
</view>


