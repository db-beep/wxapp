<view class="container">
  <view class="search-section">
    <view class="section-header">
      <view class="header-left">
        <van-icon name="search" size="18" color="#ffffff" />
        <text class="section-title">非遗传承活动查看</text>
      </view>
      <view class="header-right">
        <text class="record-count">共 {{pager.total}} 条，已加载 {{showRecords.length}}</text>
      </view>
    </view>
    
    <view class="filter-wrapper" id="filter-wrapper">
      <view class="filter-container {{!isExpanded && 'filter-collapsed'}}">
        
        
        <view class="filter-group">
          <view class="filter-label">活动名称</view>
          <van-field maxlength="18" value="{{ form.name }}" data-key="form.name" bind:change="valueChange" clearable input-align="left" placeholder="请输入活动名称" />
        </view>
        <view class="filter-group" wx:if="{{!(userInfo && userInfo.role == 'institution')}}">
          <view class="filter-label">主办机构</view>
          <x-select value="{{ form.zhubf }}" url="/webu/institution/list/select" data-key="form.zhubf" bind:change="valueChange" labelField="name" valueField="id" />
        </view>
        
      </view>
      
      <!-- 展开/收起按钮 -->
      <view class="expand-btn" wx:if="{{ showExpandBtn }}" bindtap="toggleExpand">
        <text>{{ isExpanded ? '收起' : '展开' }}</text>
        <van-icon name="{{ isExpanded ? 'arrow-up' : 'arrow-down' }}" size="16" />
      </view>
      <!-- 查询按钮 -->
      <view style="padding: 0 30rpx 10rpx;">
        <van-button type="primary" size="large" round bind:click="queryData" class="search-button" loading="{{ loading }}">
        <van-icon name="search" size="16" /> 查询/刷新
        </van-button>
      </view>
    </view>
  </view>
  
  
  <view class="list-container">
    <view wx:if="{{ pager.statisticInfo}}" class="item-card">
      <text>{{pager.statisticInfo}}</text>
    </view>
    <!-- 作业列表 -->
    <block wx:for="{{ showRecords }}" wx:key="id">
    <view class="item-card">
      <view class="item-row">
        <text class="item-label">活动名称：</text>
        <view class="item-value">{{ item.name || ''}}</view>
      </view>
      <view class="item-row" >
        <text class="item-label">主办机构：</text>
        <view class="item-value" wx:if="{{item.zhubfFrn}}">{{ item.zhubfFrn.name || ''}}</view>
      </view>
      <view class="item-row">
        <text class="item-label">活动内容：</text>
        <view class="item-value">{{ item.content || ''}}</view>
      </view>
      <view class="item-row">
        <text class="item-label">报名说明：</text>
        <view class="item-value">{{ item.baomsm || ''}}</view>
      </view>
      <view class="item-row">
        <text class="item-label">活动开始时间：</text>
        <view class="item-value">
          <van-icon name="clock-o" /> {{ item.starttime || ''}}
        </view>
      </view>
      <view class="item-row">
        <text class="item-label">结束时间：</text>
        <view class="item-value">
          <van-icon name="clock-o" /> {{ item.endtime || ''}}
        </view>
      </view>
      <view class="item-row">
        <text class="item-label">限制报名人数：</text>
        <view class="item-value">{{ item.count0 || ''}}</view>
      </view>
      <view class="item-row">
        <text class="item-label">已报名人数：</text>
        <view class="item-value">{{ item.count || ''}}</view>
      </view>
      
      <!-- 操作按钮 -->
      <view class="action-area">
        <van-button size="small" round bindtap="handleDetail" data-id="{{ item.id }}" icon="info">详情</van-button>
        <van-button wx:if="{{userInfo &&( utils.toLowerCase(userInfo.role) == 'institution'  )}}"
        size="small" type="danger" round bindtap="handleDel" data-id="{{ item.id }}" icon="delete">删除</van-button>
        <van-button wx:if="{{userInfo &&( utils.toLowerCase(userInfo.role) == 'institution'  )}}"
        size="small" color="#1989fa" round bindtap="handleEdit" data-id="{{ item.id }}" icon="edit">修改</van-button>
        <van-button wx:if="{{userInfo && ( utils.toLowerCase(userInfo.role) == 'user'   )}}"
        size="small" color="rgb(101, 216, 72)" round bindtap="onAddBaomByAcid" data-id="{{ item.id }}" icon="setting-o">立即报名</van-button>
      </view>
    </view>
    </block>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{ !pager.total}}">
      <van-empty description="暂无数据" />
    </view>
  </view>
  
  <!-- 底部固定按钮栏 -->
  <view class="bottom-bar">
    <!--
    <van-button type="danger" size="large" round class="btn" bindtap="handleXXX">
    xx
    </van-button>
    -->
    <van-button wx:if="{{userInfo && ( utils.toLowerCase(userInfo.role) == 'institution'   )}}"
    type="primary" size="large" round class="btn" bindtap="boolChange" data-key="showAdd" icon="plus">
    发布非遗传承活动
    </van-button>
  </view>
  
</view>

<!-- 非遗活动报名 外键新增入口 -->
<x-baom-add
show="{{showBaom}}"
data-key="showBaom"
param="{{'{\"acid\":' +'\"'+selectedid+'\"}' }}"
bind:cancel="boolChange"
bind:callback="boolChange"
/>

<!-- 新增组件 -->
<x-culActivi-add
show="{{showAdd}}"
data-key="showAdd"
bind:cancel="boolChange"
bind:callback="callback"
/>
<!-- 编辑组件 -->
<x-culActivi-edit
show="{{showEdit}}"
selectedid="{{selectedid}}"
data-key="showEdit"
bind:cancel="boolChange"
bind:callback="callback"
/>
<!-- 详情组件 -->
<x-culActivi-detail
show="{{showDetail}}"
selectedid="{{selectedid}}"
data-key="showDetail"
bind:cancel="boolChange"
/>


<wxs module="utils">
    var isImage = function (url) {
        if (!url) return false;
        var lowerUrl = url.toLowerCase();
        return lowerUrl.indexOf('.jpg') !== -1 ||
            lowerUrl.indexOf('.jpeg') !== -1 ||
            lowerUrl.indexOf('.png') !== -1 ||
            lowerUrl.indexOf('.gif') !== -1 ||
            lowerUrl.indexOf('.bmp') !== -1 ||
            lowerUrl.indexOf('.webp') !== -1;
    };

    toLowerCase = function (en = '') {
        if(en)return en.toLowerCase()
        return en;
    }
    module.exports = {
        isImage: isImage,
        toLowerCase: toLowerCase
    };
</wxs>

