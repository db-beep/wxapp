/* pages/index/index.wxss */
.container {
    padding-bottom: 30rpx;
    background-color: #f7f8fa;
}

/* 自定义导航栏 */
.custom-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20rpx 30rpx;
    background-color: #fff;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.nav-title {
    font-size: 30rpx;
    font-weight: bold;
    color: #154d85;
}

.nav-buttons {
    display: flex;
    gap: 15rpx;
}

.nav-btn {
    font-size: 24rpx !important;
    border-radius: 30rpx !important;
}

/* 轮播图 */
.banner {
    height: 350rpx;
    margin: 20rpx 0;
    border-radius: 16rpx;
    overflow: hidden;
}

.banner-img {
    width: 100%;
    height: 100%;
}

/* 公告栏 */
.notice-bar {
    margin: 0 20rpx 20rpx;
    border-radius: 8rpx;
}

/* 内容组 */
.content-groups {
    padding: 0 20rpx;
}

.content-group {
    margin-bottom: 40rpx;
    background-color: #fff;
    border-radius: 16rpx;
    overflow: hidden;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.group-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #f2f2f2;
}


.group-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #323233;
    position: relative;
    padding-left: 24rpx;
  }
  
  .group-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 8rpx;
    height: 32rpx;
    background: linear-gradient(to bottom, #4FACFE, #00F2FE);
    border-radius: 4rpx;
  }
  

.view-all {
    display: flex;
    align-items: center;
    font-size: 24rpx;
    color: #1989fa;
}

/* 内容列表 */
.content-list {
    display: flex;
    flex-wrap: wrap;
    padding: 20rpx;
}

.content-item {
    width: 48%;
    margin: 1%;
    background-color: #fff;
    border-radius: 12rpx;
    overflow: hidden;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.content-img {
    width: 100%;
    height: 180rpx;
}

.content-info {
    padding: 16rpx;
}

.content-title {
    font-size: 24rpx;
    font-weight: bold;
    color: #323233;
    margin-bottom: 8rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
}

.content-desc {
    font-size: 24rpx;
    color: #969799;
    margin-bottom: 12rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.4;
}

.content-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 22rpx;
    color: #969799;
}

.hotness {
    display: flex;
    align-items: center;
}

.hotness text {
    margin-left: 4rpx;
}


.banner-swiper {
    height: 350rpx;
    width: 100%;
    overflow: hidden;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.banner-img {
    width: 100%;
    height: 100%;
    display: block;
}

/* 入口按钮区域 */
.entry-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    padding: 20rpx;
}

.entry-btn {
    width: 48%;
    height: 100rpx;
    margin-bottom: 20rpx;
    background: linear-gradient(135deg, #1989fa, #07c160);
    border-radius: 12rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
}
.entry-bg2 {
    background: linear-gradient(135deg, #e63c44, #e69234);
}
.entry-bg3 {
    background: linear-gradient(135deg, #334ee9, #7215db);
}
.entry-btn:active {
    transform: scale(0.98);
    box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.entry-btn text {
    color: #fff;
    font-size: 28rpx;
    font-weight: 500;
    margin-left: 10rpx;
}


.section-header {
    margin-bottom: 30rpx;
    text-align: center;
}

  .section-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    position: relative;
    padding-bottom: 10rpx;
  }
  
  .section-line {
    margin: 10rpx auto;
    width: 80rpx;
    height: 6rpx;
    background: linear-gradient(90deg, #667eea, #764ba2);
    border-radius: 3rpx;
  }

/* 统计卡片容器 */
.statistic-container {
    display: flex;              /* 开启Flex布局 */
    flex-wrap: wrap;            /* 允许换行 */
    justify-content: space-between; /* 子元素之间留有空隙，两端对齐 */
    padding: 20rpx;
  }

  /* 单个统计卡片 */
  .statistic-item {
    width: 48%;                 /* 宽度接近50%，利用父容器的justify-content实现间隔 */
    height: 200rpx;             /* 给一个固定高度 */
    margin-bottom: 20rpx;       /* 底部外边距，形成行间距 */
    border-radius: 16rpx;       /* 圆角 */
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); /* 好看的渐变背景色 */
    display: flex;              /* 内部也用Flex布局 */
    flex-direction: column;     /* 垂直排列 */
    justify-content: center;    /* 垂直居中 */
    align-items: center;        /* 水平居中 */
    color: #fff;                /* 文字颜色为白色 */
    box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3); /* 添加阴影，增加立体感 */
    transition: all 0.3s ease; /* 添加过渡效果，让hover更平滑 */
  }

  /* 点击时的悬浮效果 */
  .statistic-item-hover {
    transform: translateY(-5rpx); /* 向上移动一点 */
    box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.4); /* 阴影加深 */
  }

  /* 数值样式 */
  .statistic-value {
    font-size: 56rpx;
    font-weight: bold;
    line-height: 1.2;
  }

  /* 名称样式 */
  .statistic-name {
    font-size: 28rpx;
    margin-top: 10rpx;
    opacity: 0.9; /* 稍微透明一点，更有层次感 */
  }
