/* 整体容器 */
.profile-container {
    padding-bottom: 40rpx;
    background-color: #f7f8fa;
    min-height: 100vh;
  }
  
  /* 顶部背景区域 */
  .profile-header {
    position: relative;
    overflow: hidden;
    padding: 40rpx 0;
  }
  
  .header-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1989fa, #07c160);
    z-index: 1;
  }
  
  .profile-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 60rpx;
  }
  
  /* 头像区域 */
  .avatar-section {
    position: relative;
    width: 160rpx;
    height: 160rpx;
    margin-bottom: 20rpx;
  }
  
  .user-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 4rpx solid #fff;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  }
  
  .avatar-edit {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 50rpx;
    height: 50rpx;
    background-color: #1989fa;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  }
  
  /* 用户名和姓名 */
  .user-name-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 20rpx;
  }
  
  .username {
    font-size: 36rpx;
    font-weight: bold;
    color: #fff;
    margin-bottom: 8rpx;
  }
  
  .realname {
    font-size: 28rpx;
    color: rgba(255, 255, 255, 0.8);
  }
  

  /* 个人信息卡片样式 */
.info-card {
    background: #fff;
    border-radius: 12px;
    padding: 16px;
    margin: 16px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }
  
  .card-title {
    font-size: 18px;
    font-weight: 600;
    color: #323233;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f2f3f5;
  }
  
  .info-item {
    display: flex;
    align-items: flex-start;
    padding-bottom: 14px;
    border-bottom: 1px solid #f7f8fa;
  }
  
  .info-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  
  .info-label {
    display: flex;
    align-items: center;
    width: 80px;
    flex-shrink: 0;
  }
  
  .info-label text {
    font-size: 14px;
    color: #646566;
    margin-left: 6px;
  }
  
  .info-value {
      margin-left: 20rpx;
    flex: 1;
    font-size: 14px;
    color: #323233;
    line-height: 1.5;
    word-break: break-all;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  
  .tags-container {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  
  .user-tag {
    margin-right: 0;
  }
  
  .edit-btn {
    margin-top: 20rpx;
    padding: 0 5rpx;
  }

  /* 学生功能区域 */
.function-section {
    margin: 40rpx 0;
    padding: 0 30rpx;
  }
  
  .section-header {
    display: flex;
    flex-direction: column;
    margin-bottom: 30rpx;
  }
  
  .section-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    position: relative;
    padding-bottom: 10rpx;
  }
  
  .section-line {
    width: 80rpx;
    height: 6rpx;
    background: linear-gradient(90deg, #667eea, #764ba2);
    border-radius: 3rpx;
    margin-top: 10rpx;
  }
  
  .function-grid {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
  }
  
  .function-card {
    width: 31%;
    background: #fff;
    border-radius: 16rpx;
    overflow: hidden;
    box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
    margin-bottom: 20rpx;
    transition: all 0.3s ease;
    position: relative;
  }
  
  .function-card:active {
    transform: translateY(4rpx);
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  }
  
  .card-header {
    height: 120rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .function-card:nth-child(3n+1) .card-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }
  .function-card:nth-child(3n+2) .card-header {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  }
  .function-card:nth-child(3n+3) .card-header {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  }
  
  .card-header::before {
    content: '';
    position: absolute;
    top: -20rpx;
    right: -20rpx;
    width: 80rpx;
    height: 80rpx;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
  }
  
  .card-body {
    padding: 20rpx;
    text-align: center;
  }
  
  .card-title {
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
  }
  
  .card-desc {
    font-size: 22rpx;
    color: #999;
    display: block;
  }
  

  /* 收藏区域样式 */
.collection-section {
    margin-top: 30rpx;
    padding: 0 24rpx;
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
  }
  
  .section-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #323233;
  }
  
  .collection-scroll {
    width: 100%;
    white-space: nowrap;
    overflow: hidden;
  }
  
  .collection-list {
    display: inline-flex;
    padding: 10rpx 0 20rpx;
  }
  
  .collection-item {
    display: inline-block;
    width: 280rpx;
    margin-right: 20rpx;
    border-radius: 16rpx;
    overflow: hidden;
    background-color: #fff;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
  }
  
  .collection-item:active {
    transform: scale(0.98);
    box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.12);
  }
  
  .collection-image {
    width: 100%;
    height: 180rpx;
    display: block;
  }
  
  .collection-info {
    padding: 16rpx;
  }
  
  .collection-title {
    display: block;
    font-size: 28rpx;
    font-weight: 500;
    color: #323233;
    margin-bottom: 8rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  
  .collection-desc {
    font-size: 20rpx;
    color: #666;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .collection-time {
    font-size: 24rpx;
    color: #969799;
  }
  

/* 空收藏状态样式 */
.empty-collection {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 150rpx;
    background-color: #f7f8fa;
    border-radius: 16rpx;
  }
  
  .empty-text {
    font-size: 28rpx;
    color: #c8c9cc;
  }
  


  
/* 入口按钮区域 */
.entry-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
}

.entry-btn {
    width: 48%;
    height: 100rpx;
    margin-bottom: 20rpx;
    background: linear-gradient(135deg, #1989fa, #07c160);
    border-radius: 12rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
}
.entry-bg2 {
    background: linear-gradient(135deg, #e63c44, #e69234);
}
.entry-bg3 {
    background: linear-gradient(135deg, #334ee9, #7215db);
}
.entry-btn:active {
    transform: scale(0.98);
    box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.entry-btn text {
    color: #fff;
    font-size: 28rpx;
    font-weight: 500;
    margin-left: 10rpx;
}